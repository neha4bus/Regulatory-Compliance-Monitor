# AI Regulatory Compliance Monitor Environment Variables

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Qodo AI Configuration
QODO_API_KEY=your_qodo_api_key_here
QODO_API_URL=https://api.qodo.ai

# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_CHANNEL_COMPLIANCE=#compliance-alerts
SLACK_CHANNEL_GENERAL=#general

# Apify Configuration
APIFY_API_TOKEN=your_apify_api_token
APIFY_ACTOR_ID=your_regulatory_scraper_actor_id

# Application Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Demo Configuration
DEMO_MODE=true
DEMO_DATA_PATH=./demo-data