{
  "name": "ai-regulatory-compliance-monitor",
  "version": "1.0.0",
  "description": "AI-powered regulatory compliance monitoring system for Oil & Gas industry",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "api": "ts-node src/api/server.ts",
    "demo": "ts-node src/demo-runner.ts",
    "demo:quick": "ts-node src/demo-runner.ts --quick",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:integration": "jest src/integration/__tests__/integration.test.ts",
    "lint": "eslint src/**/*.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "keywords": [
    "regulatory",
    "compliance",
    "ai",
    "oil-gas",
    "monitoring",
    "hackathon"
  ],
  "author": "AI Regulatory Compliance Team",
  "license": "MIT",
  "dependencies": {
    "@slack/web-api": "^6.10.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "redis": "^4.6.0",
    "uuid": "^9.0.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.1.2",
    "jsdom": "^26.1.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
